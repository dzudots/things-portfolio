# Copy to Railway variables (do not commit real secrets)

THINGS_SECRET_KEY=
THINGS_DATA_KEY=
# Prefer Railway Postgres: set THINGS_DATABASE_URL=${{Postgres.DATABASE_URL}}
# or rely on DATABASE_URL from the Postgres plugin
DATABASE_URL=
THINGS_UPLOAD_DIR=/data/uploads/scans

# Optional: production smoke script (local or CI)
# THINGS_PROD_URL=https://things-portfolio-production.up.railway.app
THINGS_FREE_SCANS_PER_DAY=5
THINGS_PRO_SCANS_PER_DAY=50
THINGS_PRO_ITEM_LIMIT=200
# Promo codes activate Pro without payment: CODE:DAYS,CODE2:DAYS
THINGS_PRO_PROMO_CODES=STAKBETA30:30,STAKPRO90:90
THINGS_USD_RUB=90

# Admin API (/api/admin/*) — comma-separated emails and/or shared key
THINGS_ADMIN_EMAILS=
THINGS_ADMIN_API_KEY=

# YooKassa (optional — leave empty until shop is ready)
THINGS_YOOKASSA_SHOP_ID=
THINGS_YOOKASSA_SECRET_KEY=
# THINGS_PRO_PRICE_RUB=299

# Optional Telegram (alert push + distribution)
THINGS_TELEGRAM_BOT_TOKEN=
THINGS_TELEGRAM_BOT_USERNAME=       # optional; resolved via getMe if empty
THINGS_PUBLIC_BASE_URL=https://things-portfolio-production.up.railway.app
THINGS_TELEGRAM_WEBHOOK_SECRET=     # optional; set same in setWebhook + validate header
# THINGS_TELEGRAM_POLLING=1         # local dev only — do not use on Railway prod

# AI via Poe (OpenAI-compatible). Vision scan needs an image→text bot.
# Recommended: claude-haiku-4.5 (cheap + vision). Alt: gemini-2.5-flash-lite
# THINGS_AI_FORCE_MOCK=1            # force mock even with key
THINGS_AI_API_KEY=                  # sk-poe-... from poe.com
THINGS_AI_BASE_URL=https://api.poe.com/v1
THINGS_AI_MODEL=claude-haiku-4.5
THINGS_AI_MARKUP_PCT=15
THINGS_AI_TIMEOUT_SEC=60
